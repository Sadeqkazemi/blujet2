    "/reporting/sales-chart": {
      "get": {
        "operationId": "ReportingController_salesChart",
        "parameters": [
          {
            "name": "granularity",
            "required": false,
            "in": "query",
            "schema": {
              "example": "q6",
              "type": "string",
              "enum": [
                "day",
                "month",
                "q3",
                "q6",
                "year",
                "flight"
              ]
            }
          },
          {
            "name": "periodStart",
            "required": false,
            "in": "query",
            "description": "Required for granularity=month — ISO date of the 1st of that month (UTC)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": false,
            "in": "query",
            "description": "Required for granularity=day — ISO date (UTC)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNo",
            "required": false,
            "in": "query",
            "description": "Required for granularity=flight",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Channel-split sales bars, shared identically by all 6 panels dashboards",
        "tags": [
          "reporting"
        ]
      }
    },
