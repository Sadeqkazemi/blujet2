{
  "openapi": "3.0.0",
  "paths": {
    "/auth/staff/login": {
      "post": {
        "operationId": "AuthController_staffLogin",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffLoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Challenge issued"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "403": {
            "description": "Account suspended"
          }
        },
        "summary": "Step 1 of staff login: verify username/password, issue a 2FA challenge",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/staff/login/verify": {
      "post": {
        "operationId": "AuthController_verifyTwoFactor",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyTwoFactorDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login complete"
          },
          "401": {
            "description": "Invalid/expired code"
          }
        },
        "summary": "Step 2 of staff login: verify the 2FA code, issue tokens",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Rotate the refresh token and issue a new access token",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Revoke the current refresh token",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Current authenticated user's identity and role",
        "tags": [
          "auth"
        ]
      }
    },
    "/panels/nav": {
      "get": {
        "operationId": "PanelsController_getNav",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Caller's role-scoped sidebar — server-computed, never client-decided",
        "tags": [
          "panels"
        ]
      }
    },
    "/panels/access": {
      "get": {
        "operationId": "PanelsController_getAccess",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Sibling panels this role may enable/disable",
        "tags": [
          "panels"
        ]
      }
    },
    "/panels/access/{panelKey}": {
      "patch": {
        "operationId": "PanelsController_setAccess",
        "parameters": [
          {
            "name": "panelKey",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePanelAccessDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Toggle a sibling panel on/off",
        "tags": [
          "panels"
        ]
      }
    },
    "/audit/manager-reports": {
      "get": {
        "operationId": "AuditController_managerReports",
        "parameters": [
          {
            "name": "category",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "actorRole",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Cross-manager oversight feed — role-scoped exclusions applied server-side",
        "tags": [
          "audit"
        ]
      }
    },
    "/audit/logs": {
      "get": {
        "operationId": "AuditController_systemLogs",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "IT Manager's system event log",
        "tags": [
          "audit"
        ]
      }
    },
    "/reporting/sales-chart": {
      "get": {
        "operationId": "ReportingController_salesChart",
        "parameters": [
          {
            "name": "granularity",
            "required": false,
            "in": "query",
            "schema": {
              "example": "q6",
              "type": "string",
              "enum": [
                "day",
                "month",
                "q3",
                "q6",
                "year",
                "flight"
              ]
            }
          },
          {
            "name": "periodStart",
            "required": false,
            "in": "query",
            "description": "Required for granularity=month — ISO date of the 1st of that month (UTC)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": false,
            "in": "query",
            "description": "Required for granularity=day — ISO date (UTC)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNo",
            "required": false,
            "in": "query",
            "description": "Required for granularity=flight",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Channel-split sales bars, shared identically by all 6 panels dashboards",
        "tags": [
          "reporting"
        ]
      }
    },
    "/reporting/kpis": {
      "get": {
        "operationId": "ReportingController_kpis",
        "parameters": [
          {
            "name": "granularity",
            "required": false,
            "in": "query",
            "schema": {
              "example": "q6",
              "type": "string",
              "enum": [
                "day",
                "month",
                "q3",
                "q6",
                "year",
                "flight"
              ]
            }
          },
          {
            "name": "periodStart",
            "required": false,
            "in": "query",
            "description": "Required for granularity=month",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": false,
            "in": "query",
            "description": "Required for granularity=day",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNo",
            "required": false,
            "in": "query",
            "description": "Required for granularity=flight",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "periodKey",
            "required": false,
            "in": "query",
            "description": "A periodKey returned by /reporting/sales-chart — re-scopes KPIs to that bucket",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Revenue/profit/cost KPI boxes — re-scopes to periodKey when provided",
        "tags": [
          "reporting"
        ]
      }
    },
    "/reporting/completed-flights-summary": {
      "get": {
        "operationId": "ReportingController_completedFlightsSummary",
        "parameters": [
          {
            "name": "granularity",
            "required": false,
            "in": "query",
            "schema": {
              "example": "q6",
              "type": "string",
              "enum": [
                "day",
                "month",
                "q3",
                "q6",
                "year",
                "flight"
              ]
            }
          },
          {
            "name": "periodStart",
            "required": false,
            "in": "query",
            "description": "Required for granularity=month",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": false,
            "in": "query",
            "description": "Required for granularity=day",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNo",
            "required": false,
            "in": "query",
            "description": "Required for granularity=flight",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "periodKey",
            "required": false,
            "in": "query",
            "description": "A periodKey returned by /reporting/sales-chart — re-scopes KPIs to that bucket",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Completed-flight seat stats, synced to the same period as the sales chart",
        "tags": [
          "reporting"
        ]
      }
    },
    "/reporting/low-sales-alerts": {
      "get": {
        "operationId": "ReportingController_lowSalesAlerts",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Flights <72h out with occupancy below threshold",
        "tags": [
          "reporting"
        ]
      }
    }
  },
  "info": {
    "title": "blujet API",
    "description": "blujet airline platform — internal API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "StaffLoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "finance.karimi",
            "description": "Staff username"
          },
          "password": {
            "type": "string",
            "example": "Blujet@1404",
            "description": "Staff password"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "VerifyTwoFactorDto": {
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string",
            "example": "a1b2c3d4-...",
            "description": "Challenge id returned by /auth/staff/login"
          },
          "code": {
            "type": "string",
            "example": "482913",
            "description": "6-digit one-time code"
          }
        },
        "required": [
          "challengeId",
          "code"
        ]
      },
      "UpdatePanelAccessDto": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "example": false
          }
        },
        "required": [
          "enabled"
        ]
      }
    }
  }
}