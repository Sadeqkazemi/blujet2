# Copy to .env (same directory as docker-compose.prod.yml) and fill in
# real values before running `docker compose -f docker-compose.prod.yml up -d --build`.

# The bare server's public IP — used to build the frontend's API base URL
# and to lock down backend CORS. No domain needed for IP-only access.
SERVER_IP=203.0.113.10

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
PII_ENCRYPTION_KEY=

# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Shared secret the backend sends to the ml-service on every internal call.
# Generate with: openssl rand -hex 24
ML_SERVICE_INTERNAL_TOKEN=

# Optional — leave empty to disable Sentry error tracking (backend and
# frontend each have their own DSN in Sentry; can be the same project).
SENTRY_DSN=
VITE_SENTRY_DSN=

# Set to true only for the very first boot to load demo/seed data
# (test accounts, sample flights). Never leave true in an ongoing deployment.
SEED_ON_START=false
