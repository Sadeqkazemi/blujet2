generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Phase 1: auth, RBAC, panel shell, audit ────────────────────────────

enum Role {
  USER
  AGENCY
  EMPLOYEE
  IT_MANAGER
  COMMERCIAL_MANAGER
  FINANCE_MANAGER
  SENIOR_MANAGER
  CEO
  BOARD_CHAIR
  SITE_ADMIN
}

model User {
  id               String    @id @default(uuid())
  role             Role
  phone            String?   @unique
  username         String?   @unique
  passwordHash     String?
  email            String?   @unique
  fullName         String
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Phase 8 (Employee management) — only meaningful for role=EMPLOYEE.
  dept               String?
  rank               String?
  referralScope      EmployeeReferralScope?
  mustChangePassword Boolean                @default(false)
  createdById        String?
  createdBy          User?                  @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  employeesCreated   User[]                 @relation("EmployeeCreatedBy")

  employeePermissions     EmployeePermission[] @relation("EmployeePermissionHolder")
  passwordResetsReceived  PasswordResetEvent[] @relation("PasswordResetTarget")
  passwordResetsPerformed PasswordResetEvent[] @relation("PasswordResetActor")
  securityPolicyUpdates   SecurityPolicy[]     @relation("SecurityPolicyUpdatedBy")
  backupsTriggered        BackupRecord[]       @relation("BackupTriggeredBy")
  seatLocksCreated        SeatLock[]           @relation("SeatLockedBy")
  seatLocksReleased       SeatLock[]           @relation("SeatLockReleasedBy")
  seatLocksApproved       SeatLock[]           @relation("SeatLockApprovedBy")
  seatLocksRejected       SeatLock[]           @relation("SeatLockRejectedBy")

  refreshTokens        RefreshToken[]
  twoFactorChallenges  TwoFactorChallenge[]
  auditLogs            AuditLog[]           @relation("AuditActor")
  panelAccessUpdates   PanelAccessFlag[]    @relation("PanelAccessUpdatedBy")
  systemSettingUpdates SystemSetting[]      @relation("SystemSettingUpdatedBy")
  ledgerEntries        LedgerEntry[]        @relation("LedgerCreatedBy")

  agencyProfile               AgencyProfile?            @relation("AgencyUser")
  agencyCreditUpdates         AgencyCreditLine[]        @relation("AgencyCreditUpdatedBy")
  agencyRequestsReferred      AgencyMembershipRequest[] @relation("AgencyRequestReferredTo")
  agencyRequestsReviewed      AgencyMembershipRequest[] @relation("AgencyRequestReviewedBy")
  agencyInvoicesIssued        AgencyInvoice[]           @relation("AgencyInvoiceIssuedBy")
  agencyMessagesSent          AgencyMessage[]           @relation("AgencyMessageSender")
  agencyCreditRequestsDecided AgencyCreditRequest[]     @relation("AgencyCreditRequestDecidedBy")

  cartableTasks       CartableTask[]             @relation("CartableAssignee")
  cartableTasksSent   CartableTask[]             @relation("CartableSender")
  cartableTransfersIn CartableTask[]             @relation("CartableTransferredTo")
  referralsSent       ManagerReferral[]          @relation("ReferralFrom")
  referralsReceived   ManagerReferralRecipient[] @relation("ReferralRecipient")
  referralReports     ManagerReferralReport[]    @relation("ReferralReportFrom")
  managerMessagesSent ManagerMessage[]           @relation("ManagerMessageFrom")
  chairPermRequests   ChairReportPermission[]    @relation("ChairPermRequester")
  chairPermDecisions  ChairReportPermission[]    @relation("ChairPermDecider")
  storedFiles         StoredFile[]               @relation("StoredFileOwner")

  clubMembership    ClubMember?       @relation("ClubMemberUser")
  clubCardDecisions ClubCardRequest[] @relation("ClubCardDecider")

  pricingProposalsMade     FarePricingProposal[] @relation("PricingProposedBy")
  pricingProposalsApproved FarePricingProposal[] @relation("PricingApprovedBy")

  refundAssignments RefundRequest[] @relation("RefundAssignee")
  refundsProcessed  RefundRequest[] @relation("RefundProcessedBy")

  bookings                Booking[]         @relation("BookingUser")
  promoRedemptions        PromoRedemption[] @relation("PromoRedeemedBy")
  walletEntries           WalletEntry[]     @relation("WalletOwner")
  priceLocks              PriceLock[]       @relation("PriceLockOwner")
  agencyAllotmentsCreated AgencyAllotment[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum TwoFactorPurpose {
  STAFF_LOGIN_2FA
  // Customer-facing phone+OTP login (public purchase engine) — reuses the
  // same challenge/code/attempts machinery as staff 2FA instead of a
  // parallel table.
  CUSTOMER_OTP_LOGIN
}

model TwoFactorChallenge {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    TwoFactorPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int              @default(0)
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@map("two_factor_challenges")
}

enum AuditCategory {
  AGENCY
  PRICING
  FINANCE
  REFUND
  STRATEGY
  SYSTEM
  CLUB
  ACCOUNT
  ACCESS
  SECURITY
  RESERVATION
}

model AuditLog {
  id         String        @id @default(uuid())
  actorId    String
  actor      User          @relation("AuditActor", fields: [actorId], references: [id])
  actorRole  Role
  category   AuditCategory
  action     String
  detail     String
  entityType String?
  entityId   String?
  metadata   Json?
  requestId  String?
  createdAt  DateTime      @default(now())

  @@index([actorRole, category, createdAt])
  @@map("audit_logs")
}

// Phase 12: key-value store for تنظیمات سامانه. The chair mock's refund-rule
// inputs deliberately do NOT live here — they write the real Phase 7
// RefundPenaltyRule rows so the engine and the settings screen never disagree.
model SystemSetting {
  key         String   @id
  value       Json
  updatedById String?
  updatedBy   User?    @relation("SystemSettingUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model PanelAccessFlag {
  panelKey    String   @id
  enabled     Boolean  @default(true)
  updatedById String?
  updatedBy   User?    @relation("PanelAccessUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt

  @@map("panel_access_flags")
}

// ─── Phase 2 (minimal slice): flight/booking core for reporting ────────

model Route {
  id          String   @id @default(uuid())
  originCode  String
  destCode    String
  // Phase 10: seeded flight duration — the add-flight form has no arrival
  // input (per design), so arrivalAt = departureAt + durationMin.
  durationMin Int      @default(120)
  flights     Flight[]

  @@unique([originCode, destCode])
  @@map("routes")
}

model Flight {
  id           String           @id @default(uuid())
  flightNo     String           @unique
  routeId      String
  route        Route            @relation(fields: [routeId], references: [id])
  aircraftType String
  instances    FlightInstance[]
  schedules    Schedule[]

  @@map("flights")
}

// Recurring flight definition (CLAUDE.md: Schedule via RRULE). Instances
// are materialized ahead of time by FlightsService.materializeSchedule —
// the RRULE string is parsed with the maintained `rrule` package, never
// hand-rolled.
model Schedule {
  id          String           @id @default(uuid())
  flightId    String
  flight      Flight           @relation(fields: [flightId], references: [id])
  rrule       String
  depHour     Int
  depMinute   Int
  durationMin Int
  capacity    Int
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  instances   FlightInstance[]

  @@map("schedules")
}

enum FlightInstanceStatus {
  SCHEDULED
  DEPARTED
  CANCELLED
}

model FlightInstance {
  id                   String               @id @default(uuid())
  flightId             String
  flight               Flight               @relation(fields: [flightId], references: [id])
  departureAt          DateTime
  arrivalAt            DateTime
  capacity             Int
  charterSeats         Int                  @default(0)
  status               FlightInstanceStatus @default(SCHEDULED)
  // Phase 10: display/plan figures from مدیریت پروازها. basePriceIrr is the
  // design's «قیمت پایه/نرخ اصلی» and the completed-flights سود/ضرر baseline —
  // NEVER the bookable price (that stays with Phase 6's registered proposal).
  basePriceIrr         Int?
  agencySeatsAllocated Int?
  // Phase 13: optional sale window — NULL on either end means "no
  // restriction" (every pre-existing instance keeps working unchanged).
  saleStartsAt         DateTime?
  saleEndsAt           DateTime?
  // Phase 13: the physical tail number for this specific departure
  // (display-only — no booking logic reads it; a recurring Flight/Schedule
  // keeps one aircraftType across dates, but the actual airframe varies
  // per-departure in reality).
  aircraftRegistration String?
  // Phase 13: per-instance override of Flight.aircraftType, set only by
  // FlightsService.changeAircraftType — falls back to Flight.aircraftType
  // when null. Deliberately NOT a mutation of the shared Flight row, which
  // would silently change every other instance of the same schedule.
  aircraftTypeOverride String?
  // Advisory ML suggestion for future flights that have no Phase 6 proposal
  // yet (same PersistedAiSuggestion shape; includes modelVersion).
  aiSuggestion         Json?
  // Set when this instance was materialized from a recurring Schedule;
  // @@unique below makes re-materialization idempotent.
  scheduleId           String?
  schedule             Schedule?            @relation(fields: [scheduleId], references: [id])
  bookings             Booking[]
  pricing              FarePricingProposal?
  seatLocks            SeatLock[]
  cabinFares           CabinFare[]
  priceLocks           PriceLock[]
  fareRules            FareRule[]
  agencyAllotments     AgencyAllotment[]

  @@unique([scheduleId, departureAt])
  @@index([departureAt])
  @@map("flight_instances")
}

enum CabinClass {
  ECONOMY
  BUSINESS
}

// ─── Public purchase engine (customer track) ────────────────────────────
// Reconciles DB_SCHEMA.md's "Open items" note: Booking/Passenger/LedgerEntry
// above were a forward-compatible guess for this track. Everything below is
// additive — no existing column/model from Phases 1-12 is changed in a
// backward-incompatible way.

// Per-cabin bookable price (CLAUDE.md: Economy + Business, priced
// independently). Falls back to FarePricingProposal.registeredPriceIrr (or
// the reservation module's flat fallback) for ECONOMY, and a fixed
// multiplier for BUSINESS, when no row exists yet — see pricing.ts.
model CabinFare {
  id               String         @id @default(uuid())
  flightInstanceId String
  flightInstance   FlightInstance @relation(fields: [flightInstanceId], references: [id])
  cabin            CabinClass
  priceIrr         Int
  updatedAt        DateTime       @updatedAt

  @@unique([flightInstanceId, cabin])
  @@map("cabin_fares")
}

// IATA-style fare-class buckets (Y/B/M …) inside a cabin. When rows exist
// for an instance+cabin, the bookable price is the CHEAPEST class that
// still has allocation left (sold count = bookings holding that class);
// when none exist, pricing falls back to CabinFare — see pricing.ts.
model FareRule {
  id                 String           @id @default(uuid())
  flightInstanceId   String
  flightInstance     FlightInstance   @relation(fields: [flightInstanceId], references: [id])
  cabin              CabinClass
  classCode          String
  priceIrr           Int
  seatsAllocated     Int
  refundable         Boolean          @default(true)
  // Phase 13 Part B — see docs/DB_SCHEMA.md for the full reasoning behind
  // each field, and what's deliberately NOT here (ticketing deadline, a
  // separate per-class cancellation-penalty schedule, min sale capacity).
  changeable         Boolean          @default(true)
  taxIrr             Int              @default(0)
  baggageAllowanceKg Int?
  validFrom          DateTime?
  validUntil         DateTime?
  // Empty = all channels allowed (matches the NULL-means-unrestricted
  // convention of validFrom/validUntil and Part A's sale window).
  allowedChannels    BookingChannel[] @default([])

  @@unique([flightInstanceId, cabin, classCode])
  @@map("fare_rules")
}

// Matches the finance/sales-chart channel split used identically across all
// 6 panels (سیستمی/چارتر/آژانس). ReservationSystem's own VIP/managerial
// pseudo-channels are out of scope until Phase 9.
enum BookingChannel {
  SYSTEM
  CHARTER
  AGENCY
}

enum BookingStatus {
  DRAFT
  HELD
  PAID
  TICKETED
  CANCELLED
  EXPIRED
  REFUNDED
}

model Booking {
  id               String         @id @default(uuid())
  pnr              String         @unique
  flightInstanceId String
  flightInstance   FlightInstance @relation(fields: [flightInstanceId], references: [id])
  channel          BookingChannel
  agencyId         String?
  agency           AgencyProfile? @relation(fields: [agencyId], references: [userId])
  status           BookingStatus  @default(DRAFT)
  priceIrr         Int
  // Phase 13 Part B: tax/fee portion already included in priceIrr above,
  // broken out here purely for receipt display — set once at creation
  // from the resolved FareRule.taxIrr (0 under flat/no-fare-class
  // pricing). Never re-derived later so a receipt stays accurate even if
  // the originating FareRule is edited/deleted afterward.
  taxIrr           Int            @default(0)
  createdAt        DateTime       @default(now())

  // Public purchase engine (customer track) additions — nullable/optional
  // because staff-issued (channel=SYSTEM via reservation.pnr.service) and
  // agency bookings never set them.
  userId         String?
  user           User?      @relation("BookingUser", fields: [userId], references: [id])
  contactPhone   String?
  cabin          CabinClass @default(ECONOMY)
  // HELD bookings expire 10 minutes after creation (CLAUDE.md's hold TTL);
  // checked lazily on read (expireIfDue) rather than via a cron job.
  holdExpiresAt  DateTime?
  // Guards double-submit on booking-creation and payment-confirmation
  // endpoints — a client retry with the same key returns the same booking.
  idempotencyKey String?    @unique

  passengers        Passenger[]
  ledgerEntries     LedgerEntry[]
  refundRequests    RefundRequest[]
  promoRedemption   PromoRedemption?
  walletEntries     WalletEntry[]
  clubPointsEntries ClubPointsEntry[]
  priceLock         PriceLock?
  // Set when this booking was created by finalizing a Phase 13D managerial
  // SeatLock — the FK itself lives on SeatLock.bookingId (unique).
  seatLock          SeatLock?         @relation("SeatLockFinalizedBooking")

  // Fare-class bucket (Y/B/M) this booking consumed, when FareRule
  // pricing was in effect; null under flat CabinFare pricing.
  fareClassCode String?
  // CLAUDE.md: soft delete for bookings — hard deletes only via GDPR flow.
  deletedAt     DateTime?

  @@index([flightInstanceId, status])
  @@index([channel])
  @@index([agencyId])
  @@index([userId])
  @@map("bookings")
}

model Passenger {
  id             String    @id @default(uuid())
  bookingId      String
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fullName       String
  nationalIdEnc  String?
  // Deterministic hash alongside the existing encrypted column — added in
  // Phase 9 so ReservationSystem's «جستجوی مسافر» can do an exact national-ID
  // match without decrypting every row (same pattern as ClubMember).
  nationalIdHash String?
  mobileEnc      String?
  // Phase 9: seat assignment for a TICKETED booking — nullable because
  // Phase 1-6 seed passengers predate seat selection.
  seatCode       String?
  deletedAt      DateTime?

  @@index([nationalIdHash])
  @@map("passengers")
}

enum LedgerEntryType {
  SALE
  REFUND
  SETTLEMENT
  COMMISSION
}

model LedgerEntry {
  id              String          @id @default(uuid())
  bookingId       String?
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  type            LedgerEntryType
  signedAmountIrr Int
  occurredAt      DateTime        @default(now())
  createdById     String?
  createdBy       User?           @relation("LedgerCreatedBy", fields: [createdById], references: [id])

  // Set for agency SALE entries (mirroring booking.agencyId) and for every
  // SETTLEMENT entry (invoice payment / direct "ثبت تسویه", neither of which
  // is necessarily tied to one booking) — lets AgencyCreditLine.usedIrr be
  // derived as a single SUM(...WHERE agencyId=X) query instead of a join
  // through Booking, which SETTLEMENT rows wouldn't have anyway.
  agencyId String?
  agency   AgencyProfile? @relation("AgencyLedgerEntries", fields: [agencyId], references: [userId])

  @@index([occurredAt, type])
  @@index([agencyId, type])
  @@map("ledger_entries")
}

// ─── Phase 3: Agencies (credit, settlement, membership) ────────────────

enum AgencyTier {
  NORMAL
  SILVER
  GOLD
}

model AgencyProfile {
  userId        String     @id
  user          User       @relation("AgencyUser", fields: [userId], references: [id])
  licenseNo     String
  managerName   String
  phone         String
  email         String
  city          String
  address       String
  tier          AgencyTier @default(NORMAL)
  suspendedAt   DateTime?
  suspendReason String?
  joinedAt      DateTime   @default(now())

  creditLine     AgencyCreditLine?
  apiKeys        AgencyApiKey[]
  invoices       AgencyInvoice[]
  messages       AgencyMessage[]
  bookings       Booking[]
  ledgerEntries  LedgerEntry[]         @relation("AgencyLedgerEntries")
  creditRequests AgencyCreditRequest[]
  documents      AgencyDocument[]
  allotments     AgencyAllotment[]

  @@map("agency_profiles")
}

enum AllotmentType {
  SOFT
  HARD
}

// Phase 13 Part C: per-agency subdivision of FlightInstance.agencySeatsAllocated
// (Phase 10's coarse instance-wide quota) — see docs/DB_SCHEMA.md.
model AgencyAllotment {
  id               String         @id @default(uuid())
  agencyId         String
  agency           AgencyProfile  @relation(fields: [agencyId], references: [userId])
  flightInstanceId String
  flightInstance   FlightInstance @relation(fields: [flightInstanceId], references: [id])
  seatsAllocated   Int
  type             AllotmentType  @default(HARD)
  // Only meaningful for SOFT: once passed, this allotment is excluded from
  // the active-allotment sum (lazy, like Booking's HELD→EXPIRED) — its
  // seats return to the general agency pool without deleting the row.
  releaseAt        DateTime?
  // This agency's contracted per-seat rate; null = normal price resolution.
  contractPriceIrr Int?
  createdById      String
  createdBy        User           @relation(fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())

  @@map("agency_allotments")
}

// Only the limit is stored — "used" is always derived from LedgerEntry
// (see docs/DB_SCHEMA.md), never a mutable balance column.
model AgencyCreditLine {
  agencyId    String        @id
  agency      AgencyProfile @relation(fields: [agencyId], references: [userId])
  limitIrr    Int
  updatedById String?
  updatedBy   User?         @relation("AgencyCreditUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime      @updatedAt

  @@map("agency_credit_lines")
}

enum AgencyMembershipStatus {
  PENDING
  REFERRED
  APPROVED
  REJECTED
}

model AgencyMembershipRequest {
  id            String                 @id @default(uuid())
  applicantName String
  managerName   String
  licenseNo     String
  city          String
  phone         String
  email         String
  documents     Json?
  status        AgencyMembershipStatus @default(PENDING)
  referredToId  String?
  referredTo    User?                  @relation("AgencyRequestReferredTo", fields: [referredToId], references: [id])
  reviewNote    String?
  reviewedById  String?
  reviewedBy    User?                  @relation("AgencyRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime               @default(now())

  @@index([status])
  @@map("agency_membership_requests")
}

enum AgencyApiScope {
  FULL
  SEARCH_BOOK
  SEARCH_ONLY
}

enum AgencyApiKeyStatus {
  ACTIVE
  SUSPENDED
}

// keyHash only — the raw key is shown once at creation and never stored/retrievable again.
model AgencyApiKey {
  id          String             @id @default(uuid())
  agencyId    String
  agency      AgencyProfile      @relation(fields: [agencyId], references: [userId])
  keyHash     String             @unique
  scope       AgencyApiScope
  status      AgencyApiKeyStatus @default(ACTIVE)
  activatedAt DateTime           @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  callCount   Int                @default(0)

  @@index([agencyId])
  @@map("agency_api_keys")
}

enum AgencyInvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

model AgencyInvoice {
  id         String              @id @default(uuid())
  agencyId   String
  agency     AgencyProfile       @relation(fields: [agencyId], references: [userId])
  invoiceNo  String              @unique
  issuedById String
  issuedBy   User                @relation("AgencyInvoiceIssuedBy", fields: [issuedById], references: [id])
  issuedAt   DateTime            @default(now())
  dueAt      DateTime
  amountIrr  Int
  status     AgencyInvoiceStatus @default(UNPAID)
  paidAt     DateTime?

  @@index([agencyId, status])
  @@map("agency_invoices")
}

model AgencyMessage {
  id             String        @id @default(uuid())
  agencyId       String
  agency         AgencyProfile @relation(fields: [agencyId], references: [userId])
  senderId       String
  sender         User          @relation("AgencyMessageSender", fields: [senderId], references: [id])
  senderIsAgency Boolean
  body           String
  createdAt      DateTime      @default(now())

  @@index([agencyId, createdAt])
  @@map("agency_messages")
}

// ─── Agency Portal (self-service) ───────────────────────────────────────
// Separate track, reassigned into this session by explicit user approval.
// See docs/API.md / docs/DB_SCHEMA.md → "Agency Portal".

enum AgencyCreditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ⚑ Replaces the design's client-side "افزایش اعتبار" mutation with an
// auditable request — only AgenciesService.updateCredit (Phase 3, unchanged)
// can ever actually change AgencyCreditLine.limitIrr.
model AgencyCreditRequest {
  id                String                    @id @default(uuid())
  agencyId          String
  agency            AgencyProfile             @relation(fields: [agencyId], references: [userId])
  requestedLimitIrr Int
  note              String?
  status            AgencyCreditRequestStatus @default(PENDING)
  decidedById       String?
  decidedBy         User?                     @relation("AgencyCreditRequestDecidedBy", fields: [decidedById], references: [id])
  decidedAt         DateTime?
  createdAt         DateTime                  @default(now())

  @@index([agencyId, status])
  @@map("agency_credit_requests")
}

enum AgencyDocumentType {
  LICENSE
  CONTRACT
  OTHER
}

enum AgencyDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

// Staff-side review is deferred (see docs) — every row stays PENDING until
// that workflow is built; the status enum exists now to stay forward-compatible.
model AgencyDocument {
  id        String               @id @default(uuid())
  agencyId  String
  agency    AgencyProfile        @relation(fields: [agencyId], references: [userId])
  fileId    String               @unique
  file      StoredFile           @relation(fields: [fileId], references: [id])
  docType   AgencyDocumentType
  status    AgencyDocumentStatus @default(PENDING)
  createdAt DateTime             @default(now())

  @@index([agencyId])
  @@map("agency_documents")
}

// ─── Phase 4: Cartable, referrals, manager messaging ────────────────────

enum CartableCategory {
  ADMIN
  AGENCY
  MANAGER
}

enum CartableSourceType {
  MANAGER_MESSAGE
  MANAGER_REFERRAL
  AGENCY_REQUEST
  CHAIR_PERMISSION
}

enum CartableStatus {
  OPEN
  APPROVED
  REJECTED
  TRANSFERRED
}

// Never authored directly — rows are materialized by real flows (manager
// message, referral, agency-request referral, chair-permission request).
// The design's review modal is تأیید/رد/انتقال with a REQUIRED note; there
// is no generic "done" state and no due date (both confirmed absent from
// all five panels). See docs/DB_SCHEMA.md Phase 4 ⚑ decisions.
model CartableTask {
  id              String              @id @default(uuid())
  assigneeId      String
  assignee        User                @relation("CartableAssignee", fields: [assigneeId], references: [id])
  category        CartableCategory
  title           String
  description     String
  senderId        String?
  sender          User?               @relation("CartableSender", fields: [senderId], references: [id])
  // Display fallback when no User row backs the sender (e.g. seed demo rows).
  senderLabelFa   String?
  sourceType      CartableSourceType?
  sourceId        String?
  status          CartableStatus      @default(OPEN)
  resolutionNote  String?
  transferredToId String?
  transferredTo   User?               @relation("CartableTransferredTo", fields: [transferredToId], references: [id])
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())

  @@index([assigneeId, status])
  @@index([sourceType, sourceId])
  @@map("cartable_tasks")
}

enum ReferralPriority {
  HIGH
  MEDIUM
  LOW
}

enum ReferralStatus {
  SENT
  REVIEWING
  REPORTED
  CLOSED
}

model ManagerReferral {
  id          String           @id @default(uuid())
  fromId      String
  from        User             @relation("ReferralFrom", fields: [fromId], references: [id])
  title       String
  body        String
  priority    ReferralPriority @default(MEDIUM)
  dueAt       DateTime?
  status      ReferralStatus   @default(SENT)
  // StoredFile ids — validated on write, resolved on read.
  attachments Json?
  createdAt   DateTime         @default(now())

  recipients ManagerReferralRecipient[]
  reports    ManagerReferralReport[]

  @@index([fromId, status])
  @@map("manager_referrals")
}

model ManagerReferralRecipient {
  referralId  String
  referral    ManagerReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User            @relation("ReferralRecipient", fields: [recipientId], references: [id])

  @@id([referralId, recipientId])
  @@index([recipientId])
  @@map("manager_referral_recipients")
}

model ManagerReferralReport {
  id          String          @id @default(uuid())
  referralId  String
  referral    ManagerReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromId      String
  from        User            @relation("ReferralReportFrom", fields: [fromId], references: [id])
  body        String
  attachments Json?
  createdAt   DateTime        @default(now())

  @@index([referralId])
  @@map("manager_referral_reports")
}

enum ManagerMessageDept {
  FINANCE
  COMMERCIAL
  SUPPORT
  AGENCIES
  CEO
  ALL_MANAGERS
}

// Compose is the only authoring surface; delivery materializes as
// CartableTask rows for the mapped recipients (the design has no inbox).
// SUPPORT/AGENCIES are accepted but undeliverable until Phase 8's
// employee/department model — documented PARTIAL_DELIVERY.
model ManagerMessage {
  id          String             @id @default(uuid())
  fromId      String
  from        User               @relation("ManagerMessageFrom", fields: [fromId], references: [id])
  toDept      ManagerMessageDept
  subject     String
  body        String
  attachments Json?
  createdAt   DateTime           @default(now())

  @@index([fromId, createdAt])
  @@map("manager_messages")
}

enum ChairPermissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// The Finance/Commercial cartable gate banner. The request creates a
// BOARD_CHAIR cartable task; the chair's تأیید/رد on that task decides it.
model ChairReportPermission {
  id          String                @id @default(uuid())
  requesterId String
  requester   User                  @relation("ChairPermRequester", fields: [requesterId], references: [id])
  status      ChairPermissionStatus @default(PENDING)
  decidedById String?
  decidedBy   User?                 @relation("ChairPermDecider", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime              @default(now())

  @@index([requesterId, status])
  @@map("chair_report_permissions")
}

// Minimal upload backing for the referral/message «بارگذاری مستندات» chips.
// PDF/image only, size-capped; bytes live on local disk in dev behind an
// interface (path column), never in the DB.
model StoredFile {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation("StoredFileOwner", fields: [ownerId], references: [id])
  fileName  String
  mimeType  String
