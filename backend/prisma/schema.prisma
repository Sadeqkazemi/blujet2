generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Phase 1: auth, RBAC, panel shell, audit ────────────────────────────

enum Role {
  USER
  AGENCY
  EMPLOYEE
  IT_MANAGER
  COMMERCIAL_MANAGER
  FINANCE_MANAGER
  SENIOR_MANAGER
  CEO
  BOARD_CHAIR
  SITE_ADMIN
}

model User {
  id               String    @id @default(uuid())
  role             Role
  phone            String?   @unique
  username         String?   @unique
  passwordHash     String?
  email            String?   @unique
  fullName         String
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Phase 8 (Employee management) — only meaningful for role=EMPLOYEE.
  dept               String?
  rank               String?
  referralScope      EmployeeReferralScope?
  mustChangePassword Boolean                @default(false)
  createdById        String?
  createdBy          User?                  @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  employeesCreated   User[]                 @relation("EmployeeCreatedBy")

  employeePermissions      EmployeePermission[]  @relation("EmployeePermissionHolder")
  passwordResetsReceived   PasswordResetEvent[]  @relation("PasswordResetTarget")
  passwordResetsPerformed  PasswordResetEvent[]  @relation("PasswordResetActor")
  securityPolicyUpdates    SecurityPolicy[]      @relation("SecurityPolicyUpdatedBy")
  backupsTriggered         BackupRecord[]        @relation("BackupTriggeredBy")
  seatLocksCreated         SeatLock[]            @relation("SeatLockedBy")
  seatLocksReleased        SeatLock[]            @relation("SeatLockReleasedBy")

  refreshTokens       RefreshToken[]
  twoFactorChallenges TwoFactorChallenge[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  panelAccessUpdates  PanelAccessFlag[]    @relation("PanelAccessUpdatedBy")
  ledgerEntries       LedgerEntry[]        @relation("LedgerCreatedBy")

  agencyProfile          AgencyProfile?            @relation("AgencyUser")
  agencyCreditUpdates    AgencyCreditLine[]        @relation("AgencyCreditUpdatedBy")
  agencyRequestsReferred AgencyMembershipRequest[] @relation("AgencyRequestReferredTo")
  agencyRequestsReviewed AgencyMembershipRequest[] @relation("AgencyRequestReviewedBy")
  agencyInvoicesIssued   AgencyInvoice[]           @relation("AgencyInvoiceIssuedBy")
  agencyMessagesSent     AgencyMessage[]           @relation("AgencyMessageSender")
  agencyCreditRequestsDecided AgencyCreditRequest[] @relation("AgencyCreditRequestDecidedBy")

  cartableTasks       CartableTask[]             @relation("CartableAssignee")
  cartableTasksSent   CartableTask[]             @relation("CartableSender")
  cartableTransfersIn CartableTask[]             @relation("CartableTransferredTo")
  referralsSent       ManagerReferral[]          @relation("ReferralFrom")
  referralsReceived   ManagerReferralRecipient[] @relation("ReferralRecipient")
  referralReports     ManagerReferralReport[]    @relation("ReferralReportFrom")
  managerMessagesSent ManagerMessage[]           @relation("ManagerMessageFrom")
  chairPermRequests   ChairReportPermission[]    @relation("ChairPermRequester")
  chairPermDecisions  ChairReportPermission[]    @relation("ChairPermDecider")
  storedFiles         StoredFile[]               @relation("StoredFileOwner")

  clubMembership    ClubMember?       @relation("ClubMemberUser")
  clubCardDecisions ClubCardRequest[] @relation("ClubCardDecider")

  pricingProposalsMade     FarePricingProposal[] @relation("PricingProposedBy")
  pricingProposalsApproved FarePricingProposal[] @relation("PricingApprovedBy")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

enum TwoFactorPurpose {
  STAFF_LOGIN_2FA
}

model TwoFactorChallenge {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    TwoFactorPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int              @default(0)
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@map("two_factor_challenges")
}

enum AuditCategory {
  AGENCY
  PRICING
  FINANCE
  REFUND
  STRATEGY
  SYSTEM
  CLUB
  ACCOUNT
  ACCESS
  SECURITY
  RESERVATION
}

model AuditLog {
  id         String        @id @default(uuid())
  actorId    String
  actor      User          @relation("AuditActor", fields: [actorId], references: [id])
  actorRole  Role
  category   AuditCategory
  action     String
  detail     String
  entityType String?
  entityId   String?
  metadata   Json?
  requestId  String?
  createdAt  DateTime      @default(now())

  @@index([actorRole, category, createdAt])
  @@map("audit_logs")
}

model PanelAccessFlag {
  panelKey    String   @id
  enabled     Boolean  @default(true)
  updatedById String?
  updatedBy   User?    @relation("PanelAccessUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime @updatedAt

  @@map("panel_access_flags")
}

// ─── Phase 2 (minimal slice): flight/booking core for reporting ────────

model Route {
  id         String   @id @default(uuid())
  originCode String
  destCode   String
  flights    Flight[]

  @@unique([originCode, destCode])
  @@map("routes")
}

model Flight {
  id           String           @id @default(uuid())
  flightNo     String           @unique
  routeId      String
  route        Route            @relation(fields: [routeId], references: [id])
  aircraftType String
  instances    FlightInstance[]

  @@map("flights")
}

enum FlightInstanceStatus {
  SCHEDULED
  DEPARTED
  CANCELLED
}

model FlightInstance {
  id           String               @id @default(uuid())
  flightId     String
  flight       Flight               @relation(fields: [flightId], references: [id])
  departureAt  DateTime
  arrivalAt    DateTime
  capacity     Int
  charterSeats Int                  @default(0)
  status       FlightInstanceStatus @default(SCHEDULED)
  bookings     Booking[]
  pricing      FarePricingProposal?
  seatLocks    SeatLock[]

  @@index([departureAt])
  @@map("flight_instances")
}

// Matches the finance/sales-chart channel split used identically across all
// 6 panels (سیستمی/چارتر/آژانس). ReservationSystem's own VIP/managerial
// pseudo-channels are out of scope until Phase 9.
enum BookingChannel {
  SYSTEM
  CHARTER
  AGENCY
}

enum BookingStatus {
  DRAFT
  HELD
  PAID
  TICKETED
  CANCELLED
  EXPIRED
  REFUNDED
}

model Booking {
  id               String         @id @default(uuid())
  pnr              String         @unique
  flightInstanceId String
  flightInstance   FlightInstance @relation(fields: [flightInstanceId], references: [id])
  channel          BookingChannel
  agencyId         String?
  agency           AgencyProfile? @relation(fields: [agencyId], references: [userId])
  status           BookingStatus  @default(DRAFT)
  priceIrr         Int
  createdAt        DateTime       @default(now())

  passengers    Passenger[]
  ledgerEntries LedgerEntry[]

  @@index([flightInstanceId, status])
  @@index([channel])
  @@index([agencyId])
  @@map("bookings")
}

model Passenger {
  id             String  @id @default(uuid())
  bookingId      String
  booking        Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fullName       String
  nationalIdEnc  String?
  // Deterministic hash alongside the existing encrypted column — added in
  // Phase 9 so ReservationSystem's «جستجوی مسافر» can do an exact national-ID
  // match without decrypting every row (same pattern as ClubMember).
  nationalIdHash String?
  mobileEnc      String?
  // Phase 9: seat assignment for a TICKETED booking — nullable because
  // Phase 1-6 seed passengers predate seat selection.
  seatCode       String?

  @@index([nationalIdHash])
  @@map("passengers")
}

enum LedgerEntryType {
  SALE
  REFUND
  SETTLEMENT
  COMMISSION
}

model LedgerEntry {
  id              String          @id @default(uuid())
  bookingId       String?
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  type            LedgerEntryType
  signedAmountIrr Int
  occurredAt      DateTime        @default(now())
  createdById     String?
  createdBy       User?           @relation("LedgerCreatedBy", fields: [createdById], references: [id])

  // Set for agency SALE entries (mirroring booking.agencyId) and for every
  // SETTLEMENT entry (invoice payment / direct "ثبت تسویه", neither of which
  // is necessarily tied to one booking) — lets AgencyCreditLine.usedIrr be
  // derived as a single SUM(...WHERE agencyId=X) query instead of a join
  // through Booking, which SETTLEMENT rows wouldn't have anyway.
  agencyId String?
  agency   AgencyProfile? @relation("AgencyLedgerEntries", fields: [agencyId], references: [userId])

  @@index([occurredAt, type])
  @@index([agencyId, type])
  @@map("ledger_entries")
}

// ─── Phase 3: Agencies (credit, settlement, membership) ────────────────

enum AgencyTier {
  NORMAL
  SILVER
  GOLD
}

model AgencyProfile {
  userId        String     @id
  user          User       @relation("AgencyUser", fields: [userId], references: [id])
  licenseNo     String
  managerName   String
  phone         String
  email         String
  city          String
  address       String
  tier          AgencyTier @default(NORMAL)
  suspendedAt   DateTime?
  suspendReason String?
  joinedAt      DateTime   @default(now())

  creditLine     AgencyCreditLine?
  apiKeys        AgencyApiKey[]
  invoices       AgencyInvoice[]
  messages       AgencyMessage[]
  bookings       Booking[]
  ledgerEntries  LedgerEntry[]         @relation("AgencyLedgerEntries")
  creditRequests AgencyCreditRequest[]
  documents      AgencyDocument[]

  @@map("agency_profiles")
}

// Only the limit is stored — "used" is always derived from LedgerEntry
// (see docs/DB_SCHEMA.md), never a mutable balance column.
model AgencyCreditLine {
  agencyId    String        @id
  agency      AgencyProfile @relation(fields: [agencyId], references: [userId])
  limitIrr    Int
  updatedById String?
  updatedBy   User?         @relation("AgencyCreditUpdatedBy", fields: [updatedById], references: [id])
  updatedAt   DateTime      @updatedAt

  @@map("agency_credit_lines")
}

enum AgencyMembershipStatus {
  PENDING
  REFERRED
  APPROVED
  REJECTED
}

model AgencyMembershipRequest {
  id            String                 @id @default(uuid())
  applicantName String
  managerName   String
  licenseNo     String
  city          String
  phone         String
  email         String
  documents     Json?
  status        AgencyMembershipStatus @default(PENDING)
  referredToId  String?
  referredTo    User?                  @relation("AgencyRequestReferredTo", fields: [referredToId], references: [id])
  reviewNote    String?
  reviewedById  String?
  reviewedBy    User?                  @relation("AgencyRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  createdAt     DateTime               @default(now())

  @@index([status])
  @@map("agency_membership_requests")
}

enum AgencyApiScope {
  FULL
  SEARCH_BOOK
  SEARCH_ONLY
}

enum AgencyApiKeyStatus {
  ACTIVE
  SUSPENDED
}

// keyHash only — the raw key is shown once at creation and never stored/retrievable again.
model AgencyApiKey {
  id          String             @id @default(uuid())
  agencyId    String
  agency      AgencyProfile      @relation(fields: [agencyId], references: [userId])
  keyHash     String             @unique
  scope       AgencyApiScope
  status      AgencyApiKeyStatus @default(ACTIVE)
  activatedAt DateTime           @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  callCount   Int                @default(0)

  @@index([agencyId])
  @@map("agency_api_keys")
}

enum AgencyInvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

model AgencyInvoice {
  id         String              @id @default(uuid())
  agencyId   String
  agency     AgencyProfile       @relation(fields: [agencyId], references: [userId])
  invoiceNo  String              @unique
  issuedById String
  issuedBy   User                @relation("AgencyInvoiceIssuedBy", fields: [issuedById], references: [id])
  issuedAt   DateTime            @default(now())
  dueAt      DateTime
  amountIrr  Int
  status     AgencyInvoiceStatus @default(UNPAID)
  paidAt     DateTime?

  @@index([agencyId, status])
  @@map("agency_invoices")
}

model AgencyMessage {
  id             String        @id @default(uuid())
  agencyId       String
  agency         AgencyProfile @relation(fields: [agencyId], references: [userId])
  senderId       String
  sender         User          @relation("AgencyMessageSender", fields: [senderId], references: [id])
  senderIsAgency Boolean
  body           String
  createdAt      DateTime      @default(now())

  @@index([agencyId, createdAt])
  @@map("agency_messages")
}

// ─── Agency Portal (self-service) ───────────────────────────────────────
// Separate track, reassigned into this session by explicit user approval.
// See docs/API.md / docs/DB_SCHEMA.md → "Agency Portal".

enum AgencyCreditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ⚑ Replaces the design's client-side "افزایش اعتبار" mutation with an
// auditable request — only AgenciesService.updateCredit (Phase 3, unchanged)
// can ever actually change AgencyCreditLine.limitIrr.
model AgencyCreditRequest {
  id                String                     @id @default(uuid())
  agencyId          String
  agency            AgencyProfile              @relation(fields: [agencyId], references: [userId])
  requestedLimitIrr Int
  note              String?
  status            AgencyCreditRequestStatus  @default(PENDING)
  decidedById       String?
  decidedBy         User?                      @relation("AgencyCreditRequestDecidedBy", fields: [decidedById], references: [id])
  decidedAt         DateTime?
  createdAt         DateTime                   @default(now())

  @@index([agencyId, status])
  @@map("agency_credit_requests")
}

enum AgencyDocumentType {
  LICENSE
  CONTRACT
  OTHER
}

enum AgencyDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

// Staff-side review is deferred (see docs) — every row stays PENDING until
// that workflow is built; the status enum exists now to stay forward-compatible.
model AgencyDocument {
  id        String                @id @default(uuid())
  agencyId  String
  agency    AgencyProfile         @relation(fields: [agencyId], references: [userId])
  fileId    String                @unique
  file      StoredFile            @relation(fields: [fileId], references: [id])
  docType   AgencyDocumentType
  status    AgencyDocumentStatus  @default(PENDING)
  createdAt DateTime              @default(now())

  @@index([agencyId])
  @@map("agency_documents")
}

// ─── Phase 4: Cartable, referrals, manager messaging ────────────────────

enum CartableCategory {
  ADMIN
  AGENCY
  MANAGER
}

enum CartableSourceType {
  MANAGER_MESSAGE
  MANAGER_REFERRAL
  AGENCY_REQUEST
  CHAIR_PERMISSION
}

enum CartableStatus {
  OPEN
  APPROVED
  REJECTED
  TRANSFERRED
}

// Never authored directly — rows are materialized by real flows (manager
// message, referral, agency-request referral, chair-permission request).
// The design's review modal is تأیید/رد/انتقال with a REQUIRED note; there
// is no generic "done" state and no due date (both confirmed absent from
// all five panels). See docs/DB_SCHEMA.md Phase 4 ⚑ decisions.
model CartableTask {
  id              String              @id @default(uuid())
  assigneeId      String
  assignee        User                @relation("CartableAssignee", fields: [assigneeId], references: [id])
  category        CartableCategory
  title           String
  description     String
  senderId        String?
  sender          User?               @relation("CartableSender", fields: [senderId], references: [id])
  // Display fallback when no User row backs the sender (e.g. seed demo rows).
  senderLabelFa   String?
  sourceType      CartableSourceType?
  sourceId        String?
  status          CartableStatus      @default(OPEN)
  resolutionNote  String?
  transferredToId String?
  transferredTo   User?               @relation("CartableTransferredTo", fields: [transferredToId], references: [id])
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())

  @@index([assigneeId, status])
  @@index([sourceType, sourceId])
  @@map("cartable_tasks")
}

enum ReferralPriority {
  HIGH
  MEDIUM
  LOW
}

enum ReferralStatus {
  SENT
  REVIEWING
  REPORTED
  CLOSED
}

model ManagerReferral {
  id          String           @id @default(uuid())
  fromId      String
  from        User             @relation("ReferralFrom", fields: [fromId], references: [id])
  title       String
  body        String
  priority    ReferralPriority @default(MEDIUM)
  dueAt       DateTime?
  status      ReferralStatus   @default(SENT)
  // StoredFile ids — validated on write, resolved on read.
  attachments Json?
  createdAt   DateTime         @default(now())

  recipients ManagerReferralRecipient[]
  reports    ManagerReferralReport[]

  @@index([fromId, status])
  @@map("manager_referrals")
}

model ManagerReferralRecipient {
  referralId  String
  referral    ManagerReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User            @relation("ReferralRecipient", fields: [recipientId], references: [id])

  @@id([referralId, recipientId])
  @@index([recipientId])
  @@map("manager_referral_recipients")
}

model ManagerReferralReport {
  id          String          @id @default(uuid())
  referralId  String
  referral    ManagerReferral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  fromId      String
  from        User            @relation("ReferralReportFrom", fields: [fromId], references: [id])
  body        String
  attachments Json?
  createdAt   DateTime        @default(now())

  @@index([referralId])
  @@map("manager_referral_reports")
}

enum ManagerMessageDept {
  FINANCE
  COMMERCIAL
  SUPPORT
  AGENCIES
  CEO
  ALL_MANAGERS
}

// Compose is the only authoring surface; delivery materializes as
// CartableTask rows for the mapped recipients (the design has no inbox).
// SUPPORT/AGENCIES are accepted but undeliverable until Phase 8's
// employee/department model — documented PARTIAL_DELIVERY.
model ManagerMessage {
  id          String             @id @default(uuid())
  fromId      String
  from        User               @relation("ManagerMessageFrom", fields: [fromId], references: [id])
  toDept      ManagerMessageDept
  subject     String
  body        String
  attachments Json?
  createdAt   DateTime           @default(now())

  @@index([fromId, createdAt])
  @@map("manager_messages")
}

enum ChairPermissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// The Finance/Commercial cartable gate banner. The request creates a
// BOARD_CHAIR cartable task; the chair's تأیید/رد on that task decides it.
model ChairReportPermission {
  id          String                @id @default(uuid())
  requesterId String
  requester   User                  @relation("ChairPermRequester", fields: [requesterId], references: [id])
  status      ChairPermissionStatus @default(PENDING)
  decidedById String?
  decidedBy   User?                 @relation("ChairPermDecider", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime              @default(now())

  @@index([requesterId, status])
  @@map("chair_report_permissions")
}

// Minimal upload backing for the referral/message «بارگذاری مستندات» chips.
// PDF/image only, size-capped; bytes live on local disk in dev behind an
// interface (path column), never in the DB.
model StoredFile {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation("StoredFileOwner", fields: [ownerId], references: [id])
  fileName  String
  mimeType  String
  sizeBytes Int
  path      String
  createdAt DateTime @default(now())

  agencyDocument AgencyDocument?

  @@index([ownerId])
  @@map("stored_files")
}

// ─── Phase 5: VIP club (manager-panel slice) ─────────────────────────────

enum ClubTier {
  SILVER
  GOLD
  PLATINUM
}

enum ClubCardStatus {
  NONE
  REVIEW
  ISSUED
}

enum ClubCardRequestStatus {
  SUBMITTED
  REFERRED
  APPROVED
  REJECTED
}

// Design's assignedTo: 'senior' | 'super' — never the CEO (the site-admin
// referral form only offers these two targets).
enum ClubCardAssignee {
  SENIOR
  CHAIR
}

// Read-model slice of the customer club: the authoritative points ledger
// belongs to the public-site track; `points` here is a display copy.
// National ID is checksum-validated, AES-encrypted at rest, with a keyed
// hash column for the design's exact-match search.
model ClubMember {
  id              String         @id @default(uuid())
  userId          String?        @unique
  user            User?          @relation("ClubMemberUser", fields: [userId], references: [id])
  fullName        String
  email           String
  birthDate       DateTime?
  nationalIdEnc   String
  nationalIdHash  String
  joinDate        DateTime       @default(now())
  points          Int            @default(0)
  level           ClubTier       @default(SILVER)
  cardStatus      ClubCardStatus @default(NONE)
  cardNo          String?
  issuedByLabelFa String?
  createdAt       DateTime       @default(now())

  requests ClubCardRequest[]

  @@index([nationalIdHash])
  @@index([level])
  @@map("club_members")
}

model ClubCardRequest {
  id          String                @id @default(uuid())
  memberId    String
  member      ClubMember            @relation(fields: [memberId], references: [id])
  level       ClubTier
  points      Int
  status      ClubCardRequestStatus @default(SUBMITTED)
  assignedTo  ClubCardAssignee?
  decidedById String?
  decidedBy   User?                 @relation("ClubCardDecider", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  cardNo      String?
  // Presentational timeline of {step, labelFa, at} rows (design's روند درخواست).
  history     Json
  createdAt   DateTime              @default(now())

  @@index([status])
  @@map("club_card_requests")
}

// ─── Phase 6: ticket pricing proposals ───────────────────────────────────

enum PricingProposalStatus {
  PENDING
  REGISTERED
}

// One live proposal per flight instance (⚑ fixes the mocks' incompatible
// PP-#### vs PP-{flightNo} id schemes). REGISTERED is locked forever per
// the design («پس از تأیید مدیر عامل، قیمت ثبت و قفل می‌شود»).
model FarePricingProposal {
  id                 String                @id @default(uuid())
  flightInstanceId   String                @unique
  flightInstance     FlightInstance        @relation(fields: [flightInstanceId], references: [id])
  basePriceIrr       Int
  competitorPriceIrr Int
  proposedPriceIrr   Int
  legalRateIrr       Int?
  note               String?
  proposedById       String
  proposedBy         User                  @relation("PricingProposedBy", fields: [proposedById], references: [id])
  status             PricingProposalStatus @default(PENDING)
  registeredPriceIrr Int?
  approvedById       String?
  approvedBy         User?                 @relation("PricingApprovedBy", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  // Advisory ML output, persisted with modelVersion for traceability —
  // { priceIrr, reason, factors[], season, occasion, confidence,
  //   modelVersion, generatedAt }. Never auto-applied.
  aiSuggestion       Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status])
  @@map("fare_pricing_proposals")
}

// ─── Phase 8: Employee management (IT Manager) ─────────────────────────

enum EmployeeReferralScope {
  MANAGERS_ONLY
  ALL_STAFF
}

/** Seeded catalog — mirrors design-reference's site-data.js PERM_CATALOG
 * exactly (dept -> sections -> perms). No custom-dept rows: a custom dept
 * has no catalog entries until product defines one. */
model Permission {
  id             String   @id @default(uuid())
  dept           String
  sectionKey     String
  sectionLabelFa String
  key            String
  labelFa        String
  createdAt      DateTime @default(now())

  employeeGrants EmployeePermission[]

  @@unique([dept, key])
  @@map("permissions")
}

model EmployeePermission {
  id           String     @id @default(uuid())
  employeeId   String
  employee     User       @relation("EmployeePermissionHolder", fields: [employeeId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedById  String?
  createdAt    DateTime   @default(now())

  @@unique([employeeId, permissionId])
  @@map("employee_permissions")
}

model InternalService {
  id        String   @id @default(uuid())
  key       String   @unique
  nameFa    String
  enabled   Boolean  @default(true)
  uptimePct Float    @default(100)
  updatedAt DateTime @updatedAt

  @@map("internal_services")
}

enum ExternalServiceMethod {
  GET
  POST
}

model ExternalServiceConfig {
  id              String                @id @default(uuid())
  key             String                @unique
  nameFa          String
  provider        String
  endpoint        String
  method          ExternalServiceMethod @default(POST)
  timeoutMs       Int                   @default(30000)
  apiKeyEncrypted String?
  sandbox         Boolean               @default(false)
  enabled         Boolean               @default(true)
  lastTestAt      DateTime?
  lastTestOk      Boolean?
  lastTestMessage String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("external_service_configs")
}

model PasswordResetEvent {
  id         String   @id @default(uuid())
  employeeId String
  employee   User     @relation("PasswordResetTarget", fields: [employeeId], references: [id], onDelete: Cascade)
  resetById  String
  resetBy    User     @relation("PasswordResetActor", fields: [resetById], references: [id])
  createdAt  DateTime @default(now())

  @@map("password_reset_events")
}

/** Singleton (id=1) — enforced in service layer via upsert-by-1. */
model SecurityPolicy {
  id                      Int      @id @default(1)
  minLength               Int      @default(10)
  expiryDays              Int      @default(90)
  maxAttempts             Int      @default(5)
  requireUppercase        Boolean  @default(true)
  requireNumber           Boolean  @default(true)
  requireSymbol           Boolean  @default(true)
  blockReuse              Boolean  @default(true)
  staffTwoFactorMandatory Boolean  @default(true)
  updatedById             String?
  updatedBy               User?    @relation("SecurityPolicyUpdatedBy", fields: [updatedById], references: [id])
  updatedAt               DateTime @updatedAt

  @@map("security_policy")
}

enum BackupStatus {
  RUNNING
  SUCCESS
  FAILED
}

model BackupRecord {
  id            String       @id @default(uuid())
  fileName      String
  sizeBytes     Int?
  status        BackupStatus @default(RUNNING)
  triggeredById String?
  triggeredBy   User?        @relation("BackupTriggeredBy", fields: [triggeredById], references: [id])
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  errorMessage  String?

  @@map("backup_records")
}

// ─── Phase 9: Reservation system (seat lock / PNR) ──────────────────────

/** Seat layout config per aircraft type — CLAUDE.md: "seat map config lives
 * per aircraft type in the DB, not hardcoded." Column letters are ordered
 * left-to-right within the row; the aisle is implied between the two
 * groups (e.g. business ["A","C"]+["D","F"] = 2-2, economy 3+3 = 2-3 per
 * the design's actual row groups, confirmed from ReservationSystem.dc.html). */
model AircraftSeatMap {
  id                String   @id @default(uuid())
  aircraftType      String   @unique
  businessRowStart  Int
  businessRowEnd    Int
  businessColsLeft  String[]
  businessColsRight String[]
  economyRowStart   Int
  economyRowEnd     Int
  economyColsLeft   String[]
  economyColsRight  String[]
  updatedAt         DateTime @updatedAt

  @@map("aircraft_seat_maps")
}

/** Managerial seat lock/reservation — prevents sale of that seat without
 * going through a Booking. Only `canLock` roles (see reservation module)
 * may create/release one. `releasedAt=null` = currently active; enforced
 * unique per (flightInstanceId, seatCode) via a partial index (migration
 * SQL) so two active locks can never coexist on the same seat. */
model SeatLock {
  id                       String    @id @default(uuid())
  flightInstanceId         String
  flightInstance           FlightInstance @relation(fields: [flightInstanceId], references: [id])
  seatCode                 String
  lockedById               String
  lockedBy                 User      @relation("SeatLockedBy", fields: [lockedById], references: [id])
  passengerName            String?
  passengerNationalIdEnc   String?
  passengerNationalIdHash  String?
  passengerMobileEnc       String?
  releasedById             String?
  releasedBy               User?     @relation("SeatLockReleasedBy", fields: [releasedById], references: [id])
  releasedAt               DateTime?
  createdAt                DateTime  @default(now())

  @@index([flightInstanceId])
  @@map("seat_locks")
}
