// ─── Phase 5: VIP club (manager-panel slice) ─────────────────────────────

enum ClubTier {
  SILVER
  GOLD
  PLATINUM
}

enum ClubCardStatus {
  NONE
  REVIEW
  ISSUED
}

enum ClubCardRequestStatus {
  SUBMITTED
  REFERRED
  APPROVED
  REJECTED
}

// Design's assignedTo: 'senior' | 'super' — never the CEO (the site-admin
// referral form only offers these two targets).
enum ClubCardAssignee {
  SENIOR
  CHAIR
}

// Read-model slice of the customer club: the authoritative points ledger
// belongs to the public-site track; `points` here is a display copy.
// National ID is checksum-validated, AES-encrypted at rest, with a keyed
// hash column for the design's exact-match search.
model ClubMember {
  id              String         @id @default(uuid())
  userId          String?        @unique
  user            User?          @relation("ClubMemberUser", fields: [userId], references: [id])
  fullName        String
  email           String
  birthDate       DateTime?
  nationalIdEnc   String
  nationalIdHash  String
  joinDate        DateTime       @default(now())
  points          Int            @default(0)
  level           ClubTier       @default(SILVER)
  cardStatus      ClubCardStatus @default(NONE)
  cardNo          String?
  issuedByLabelFa String?
  createdAt       DateTime       @default(now())

  requests      ClubCardRequest[]
  pointsEntries ClubPointsEntry[] @relation("ClubMemberPointsEntries")

  @@index([nationalIdHash])
  @@index([level])
  @@map("club_members")
}

model ClubCardRequest {
  id          String                @id @default(uuid())
  memberId    String
  member      ClubMember            @relation(fields: [memberId], references: [id])
  level       ClubTier
  points      Int
  status      ClubCardRequestStatus @default(SUBMITTED)
  assignedTo  ClubCardAssignee?
  decidedById String?
  decidedBy   User?                 @relation("ClubCardDecider", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  cardNo      String?
  // Presentational timeline of {step, labelFa, at} rows (design's روند درخواست).
  history     Json
  createdAt   DateTime              @default(now())

  @@index([status])
  @@map("club_card_requests")
}

// ─── Phase 6: ticket pricing proposals ───────────────────────────────────

enum PricingProposalStatus {
  PENDING
  REGISTERED
}

// One live proposal per flight instance (⚑ fixes the mocks' incompatible
// PP-#### vs PP-{flightNo} id schemes). REGISTERED is locked forever per
// the design («پس از تأیید مدیر عامل، قیمت ثبت و قفل می‌شود»).
model FarePricingProposal {
  id                 String                @id @default(uuid())
  flightInstanceId   String                @unique
  flightInstance     FlightInstance        @relation(fields: [flightInstanceId], references: [id])
  basePriceIrr       Int
  competitorPriceIrr Int
  proposedPriceIrr   Int
  legalRateIrr       Int?
  note               String?
  proposedById       String
  proposedBy         User                  @relation("PricingProposedBy", fields: [proposedById], references: [id])
  status             PricingProposalStatus @default(PENDING)
  registeredPriceIrr Int?
  approvedById       String?
  approvedBy         User?                 @relation("PricingApprovedBy", fields: [approvedById], references: [id])
  approvedAt         DateTime?
  // Advisory ML output, persisted with modelVersion for traceability —
  // { priceIrr, reason, factors[], season, occasion, confidence,
  //   modelVersion, generatedAt }. Never auto-applied.
  aiSuggestion       Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status])
  @@map("fare_pricing_proposals")
}

// ─── Phase 7: refunds (finance approval & payout) ────────────────────────

enum RefundStatus {
  SUBMITTED
  REVIEW
  FINANCE
  PAID
}

// ⚑ The mocks shipped three inconsistent penalty schemes; the customer
// panel's 4-bracket engine is the only executed one and is seeded here as
// the server-side source of truth (see docs/DB_SCHEMA.md Phase 7).
model RefundPenaltyRule {
  id                      String @id @default(uuid())
  minHoursBeforeDeparture Int
  penaltyPct              Int
  labelFa                 String

  @@map("refund_penalty_rules")
}

model RefundRequest {
  id               String       @id @default(uuid())
  bookingId        String
  booking          Booking      @relation(fields: [bookingId], references: [id])
  passengerName    String
  nidEnc           String?
  mobileEnc        String?
  // 24-digit شبا — encrypted at rest, decrypted only for the finance surface.
  ibanEnc          String
  totalPaidIrr     Int
  penaltyPct       Int
  penaltyAmountIrr Int
  refundableIrr    Int
  status           RefundStatus @default(SUBMITTED)
  // Design: refer sets the assignee WITHOUT advancing status.
  assigneeId       String?
  assignee         User?        @relation("RefundAssignee", fields: [assigneeId], references: [id])
  processedById    String?
  processedBy      User?        @relation("RefundProcessedBy", fields: [processedById], references: [id])
  paidAt           DateTime?
  history          Json
  createdAt        DateTime     @default(now())

  @@index([status])
  @@map("refund_requests")
}

// ─── Phase 8: Employee management (IT Manager) ─────────────────────────

enum EmployeeReferralScope {
  MANAGERS_ONLY
  ALL_STAFF
}

/**
 * Seeded catalog — mirrors design-reference's site-data.js PERM_CATALOG
 * exactly (dept -> sections -> perms). No custom-dept rows: a custom dept
 * has no catalog entries until product defines one.
 */
model Permission {
  id             String   @id @default(uuid())
  dept           String
  sectionKey     String
  sectionLabelFa String
  key            String
  labelFa        String
  createdAt      DateTime @default(now())

  employeeGrants EmployeePermission[]

  @@unique([dept, key])
  @@map("permissions")
}

model EmployeePermission {
  id           String     @id @default(uuid())
  employeeId   String
  employee     User       @relation("EmployeePermissionHolder", fields: [employeeId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedById  String?
  createdAt    DateTime   @default(now())

  @@unique([employeeId, permissionId])
  @@map("employee_permissions")
}

model InternalService {
  id        String   @id @default(uuid())
  key       String   @unique
  nameFa    String
  enabled   Boolean  @default(true)
  uptimePct Float    @default(100)
  updatedAt DateTime @updatedAt

  @@map("internal_services")
}

enum ExternalServiceMethod {
  GET
  POST
}

model ExternalServiceConfig {
  id              String                @id @default(uuid())
  key             String                @unique
  nameFa          String
  provider        String
  endpoint        String
  method          ExternalServiceMethod @default(POST)
  timeoutMs       Int                   @default(30000)
  apiKeyEncrypted String?
  sandbox         Boolean               @default(false)
  enabled         Boolean               @default(true)
  lastTestAt      DateTime?
  lastTestOk      Boolean?
  lastTestMessage String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@map("external_service_configs")
}

model PasswordResetEvent {
  id         String   @id @default(uuid())
  employeeId String
  employee   User     @relation("PasswordResetTarget", fields: [employeeId], references: [id], onDelete: Cascade)
  resetById  String
  resetBy    User     @relation("PasswordResetActor", fields: [resetById], references: [id])
  createdAt  DateTime @default(now())

  @@map("password_reset_events")
}

/**
 * Singleton (id=1) — enforced in service layer via upsert-by-1.
 */
model SecurityPolicy {
  id                      Int      @id @default(1)
  minLength               Int      @default(10)
  expiryDays              Int      @default(90)
  maxAttempts             Int      @default(5)
  requireUppercase        Boolean  @default(true)
  requireNumber           Boolean  @default(true)
  requireSymbol           Boolean  @default(true)
  blockReuse              Boolean  @default(true)
  staffTwoFactorMandatory Boolean  @default(true)
  updatedById             String?
  updatedBy               User?    @relation("SecurityPolicyUpdatedBy", fields: [updatedById], references: [id])
  updatedAt               DateTime @updatedAt

  @@map("security_policy")
}

enum BackupStatus {
  RUNNING
  SUCCESS
  FAILED
}

model BackupRecord {
  id            String       @id @default(uuid())
  fileName      String
  sizeBytes     Int?
  status        BackupStatus @default(RUNNING)
  triggeredById String?
  triggeredBy   User?        @relation("BackupTriggeredBy", fields: [triggeredById], references: [id])
  startedAt     DateTime     @default(now())
  completedAt   DateTime?
  errorMessage  String?

  @@map("backup_records")
}

// ─── Phase 9: Reservation system (seat lock / PNR) ──────────────────────

/**
 * Seat layout config per aircraft type — CLAUDE.md: "seat map config lives
 * per aircraft type in the DB, not hardcoded." Column letters are ordered
 * left-to-right within the row; the aisle is implied between the two
 * groups (e.g. business ["A","C"]+["D","F"] = 2-2, economy 3+3 = 2-3 per
 * the design's actual row groups, confirmed from ReservationSystem.dc.html).
 */
model AircraftSeatMap {
  id                String   @id @default(uuid())
  aircraftType      String   @unique
  businessRowStart  Int
  businessRowEnd    Int
  businessColsLeft  String[]
  businessColsRight String[]
  economyRowStart   Int
  economyRowEnd     Int
  economyColsLeft   String[]
  economyColsRight  String[]
  updatedAt         DateTime @updatedAt

  @@map("aircraft_seat_maps")
}

/**
 * Managerial seat lock/reservation — prevents sale of that seat without
 * going through a Booking. Only `canLock` roles (see reservation module)
 * may create/release one. `releasedAt=null` = currently active; enforced
 * unique per (flightInstanceId, seatCode) via a partial index (migration
 * SQL) so two active locks can never coexist on the same seat.
 * Phase 13 Part D: two-step governance layered onto the same row (see
 * docs/DB_SCHEMA.md) — reason, classification, requester rank, a single
 * `expiresAt` reused as both the request-decision deadline and (after
 * approval) the hold-to-ticket deadline, and a link to the booking a
 * lock gets finalized into.
 */
model SeatLock {
  id                      String         @id @default(uuid())
  flightInstanceId        String
  flightInstance          FlightInstance @relation(fields: [flightInstanceId], references: [id])
  seatCode                String
  lockedById              String
  lockedBy                User           @relation("SeatLockedBy", fields: [lockedById], references: [id])
  passengerName           String?
  passengerNationalIdEnc  String?
  passengerNationalIdHash String?
  passengerMobileEnc      String?
  releasedById            String?
  releasedBy              User?          @relation("SeatLockReleasedBy", fields: [releasedById], references: [id])
  releasedAt              DateTime?
  createdAt               DateTime       @default(now())

  reason          String             @default("")
  classification  LockClassification @default(PAYABLE)
  discountPct     Int?
  // Snapshot of lockedBy.role at request time — deliberately not a live
  // join, so the audit trail keeps showing what rank actually authorized
  // the request even if the user's role later changes.
  requesterRank   Role               @default(IT_MANAGER)
  approvalStatus  LockApprovalStatus @default(APPROVED)
  approvedById    String?
  approvedBy      User?              @relation("SeatLockApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?              @relation("SeatLockRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?
  // Request-decision deadline (createdAt + 24h) until approved, then
  // overwritten to the hold-to-ticket deadline (approvedAt + 48h). See
  // docs/DB_SCHEMA.md Phase 13 Part D.
  expiresAt       DateTime           @default(now())
  bookingId       String?            @unique
  booking         Booking?           @relation("SeatLockFinalizedBooking", fields: [bookingId], references: [id])

  @@index([flightInstanceId])
  @@map("seat_locks")
}

enum LockClassification {
  FREE
  DISCOUNTED
  PAYABLE
}

enum LockApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// ─── Phase 10: flight management (مدیریت پروازها) ──────────────────────

// ⚑ The mocks' add-flight modal takes free-text cities; the real form uses
// selects fed by this seeded catalog (CLAUDE.md's 20 Iranian cities +
// DXB/IST/NJF) so Route codes stay valid and airport-local rendering is
// possible later (tz is IANA).
model Airport {
  id            String @id @default(uuid())
  code          String @unique
  cityFa        String
  tz            String
  // Minimum connection time (minutes) for the 1-stop connection builder.
  minConnectMin Int    @default(60)

  @@map("airports")
}

// ─── Phase 13 (cont'd): promo codes, wallet, club points ledger, price lock ──
// Continues the public purchase engine port — see PLAN.md Phase 13.

enum PromoType {
  PERCENT
  FIXED
}

// CLAUDE.md: entered on پرداخت (payment), not checkout — applied inside
// BookingService.pay(), never at booking-creation time.
model PromoCode {
  id             String      @id @default(uuid())
  code           String      @unique
  type           PromoType
  value          Int
  originCode     String?
  destCode       String?
  cabin          CabinClass?
  startsAt       DateTime?
  endsAt         DateTime?
  maxRedemptions Int?
  maxPerUser     Int?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())

  redemptions PromoRedemption[]

  @@map("promo_codes")
}

// One redemption per booking (a booking is only ever paid once — see the
// HELD-conditional-update guard in BookingService.pay).
model PromoRedemption {
  id          String    @id @default(uuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id])
  userId      String
  user        User      @relation("PromoRedeemedBy", fields: [userId], references: [id])
  discountIrr Int
  createdAt   DateTime  @default(now())

  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_redemptions")
}

enum WalletEntryType {
  TOPUP
  PURCHASE
  REFUND
  ADJUST
}

// Balance is ALWAYS SUM(signedAmountIrr) — never a mutable column
// (CLAUDE.md: "User wallet ... never a mutable balance column").
model WalletEntry {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation("WalletOwner", fields: [userId], references: [id])
  type            WalletEntryType
  signedAmountIrr Int
  bookingId       String?
  booking         Booking?        @relation(fields: [bookingId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@map("wallet_entries")
}

enum ClubPointsEntryType {
  EARN
  REDEEM
  ADJUST
}

// The authoritative points ledger for the public purchase engine —
// ClubMember.points (Phase 5, staff track) is documented as a display-copy
// read-model kept in sync by writes here, never the other way around.
model ClubPointsEntry {
  id           String              @id @default(uuid())
  clubMemberId String
  clubMember   ClubMember          @relation("ClubMemberPointsEntries", fields: [clubMemberId], references: [id])
  type         ClubPointsEntryType
  signedPoints Int
  bookingId    String?
  booking      Booking?            @relation(fields: [bookingId], references: [id])
  createdAt    DateTime            @default(now())

  @@index([clubMemberId])
  @@map("club_points_entries")
}

enum PriceLockStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

// Gold-tier-and-above club members only (CLAUDE.md: "gold-tier members
// only"). Fee is NestJS-computed (flat, documented rate) — the AI-suggested
// variable fee/risk is deferred, same as the rest of Phase 13's AI wiring.
model PriceLock {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation("PriceLockOwner", fields: [userId], references: [id])
  flightInstanceId String
  flightInstance   FlightInstance  @relation(fields: [flightInstanceId], references: [id])
  cabin            CabinClass
  lockedPriceIrr   Int
  feeIrr           Int
  status           PriceLockStatus @default(ACTIVE)
  expiresAt        DateTime
  createdAt        DateTime        @default(now())
  // Set when a booking is created against this lock — lets BookingService.pay
  // skip re-pricing entirely for a locked booking (the whole point of a
  // price lock is shielding the customer from a market price change).
  bookingId        String?         @unique
  booking          Booking?        @relation(fields: [bookingId], references: [id])

  @@index([userId, status])
  @@index([flightInstanceId, cabin, status])
  @@map("price_locks")
}
