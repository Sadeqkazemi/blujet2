NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://blujet:blujet@localhost:5432/blujet?schema=public"
REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"

# Internal-only FastAPI service — never exposed to the frontend/internet.
ML_SERVICE_URL="http://ml-service:8000"
ML_SERVICE_INTERNAL_TOKEN="change-me"

# SMS OTP / notifications provider (mock in dev)
SMS_PROVIDER="mock"

# Payment gateway (Shetab/IPG) — sandbox driver in dev
PAYMENT_GATEWAY="sandbox"

# Error tracking — omit to disable in local dev
SENTRY_DSN=

CORS_ORIGINS="http://localhost:5173"

PII_ENCRYPTION_KEY="generate-with: openssl rand -hex 32"
